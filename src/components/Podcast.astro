---
<section class="podcast" id="podcast">
    <Container>
        <SectionHeading text="Sharing What I Learn" />
        <p class="subheading">Zwischen zwei Stacks — a bi-weekly product &amp; tech podcast</p>
        <p class="description">
            Together with Jens Becker, I co-host <em>Zwischen zwei Stacks</em> — a hands-on podcast
            about building real software and digital products. Every two weeks we dig into the tools,
            stacks, and decisions behind the work. No hype, just lessons from the day-to-day.
        </p>
        <div class="platforms">
            {platforms.map((platform) => (
                <a
                    href={platform.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="platform"
                    aria-label={`Listen on ${platform.name}`}
                >
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d={platform.path} />
                    </svg>
                    <span>{platform.name}</span>
                </a>
            ))}
        </div>
        <a
            href="https://www.zwischenzweistacks.de"
            target="_blank"
            rel="noopener noreferrer"
            class="cta"
        >
            Visit zwischenzweistacks.de
        </a>
    </Container>
</section>

<style>
    .podcast {
        padding: 6rem 0;
        scroll-margin-top: 5rem;
    }

    .subheading {
        font-size: 1.5rem;
        margin-bottom: 1.5rem;
        opacity: 0.8;
    }

    .description {
        font-size: 1.25rem;
        line-height: 1.6;
        max-width: 700px;
        margin-bottom: 2.5rem;
    }

    .description em {
        font-style: italic;
        color: var(--primary-color);
    }

    .platforms {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2.5rem;
    }

    .platform {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1.25rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
        color: var(--text-color);
        text-decoration: none;
        font-size: 1rem;
        transition: transform 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }

    .platform svg {
        width: 24px;
        height: 24px;
        flex-shrink: 0;
    }

    .platform:hover {
        transform: translateY(-4px);
        color: var(--primary-color);
        border-color: var(--primary-color);
    }

    .cta {
        font-family: 'JetBrains Mono', monospace;
        background-color: var(--primary-color);
        color: white;
        border: none;
        padding: 1rem 2rem;
        font-size: 1rem;
        cursor: pointer;
        transition: transform 0.2s ease;
        text-decoration: none;
        display: inline-block;
    }

    .cta:hover {
        transform: translateY(-2px);
    }

    @media (max-width: 768px) {
        .podcast {
            padding: 4rem 0;
        }

        .subheading {
            font-size: 1.25rem;
        }

        .description {
            font-size: 1rem;
        }

        .platforms {
            flex-direction: column;
            align-items: stretch;
        }

        .platform {
            justify-content: center;
        }
    }
</style>
